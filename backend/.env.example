# OpenAI or other LLM API key
OPENAI_API_KEY=your_api_key_here

# Model name (placeholder)
MODEL_NAME=gpt-4o-mini

# Embedding model for retrieval
EMBEDDING_MODEL=text-embedding-3-small

# Number of retrieved chunks to pass into chat context
RETRIEVAL_TOP_K=4

# OpenAI request timeout (seconds)
OPENAI_TIMEOUT_SEC=45

# Optional: vector store path
VECTOR_STORE_PATH=./data/vector_store.faiss

# Optional: SQLite chat persistence database
CHAT_DB_PATH=./data/chat_history.db
